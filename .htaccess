DirectoryIndex index.php

# Eliminar cualquier CSP que Apache esté inyectando
Header unset Content-Security-Policy
Header unset X-Content-Security-Policy

# Establecer tu propia CSP (más permisiva)
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https: data:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' data: https:; connect-src 'self' https:;"